{
  "name": "hrapp-workspace",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm --prefix hrApp-frontend run lint",
    "build": "npm --prefix hrApp-frontend run build",
    "check:backend": "npm --prefix hrApp-backend run check",
    "check": "npm run format:check && npm run lint && npm run build && npm run check:backend"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
